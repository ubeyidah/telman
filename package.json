{
  "name": "telman-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "build:core": "bun run --filter @telmanorg/core build",
    "build:cli": "bun run --filter @telmanorg/telman build",
    "build:local-mcp": "bun run --filter @telmanorg/mcp build",
    "release:pack:core": "bun run --filter @telmanorg/core pack:dry",
    "release:pack:cli": "bun run --filter @telmanorg/telman pack:dry",
    "release:pack:mcp": "bun run --filter @telmanorg/mcp pack:dry",
    "dev:cli": "bun run packages/cli/src/index.ts",
    "dev:remote-mcp": "bun run apps/remote-mcp/src/index.ts",
    "dev:local-mcp": "bun run packages/local-mcp/src/index.ts",
    "build:all": "turbo run build",
    "type-check": "tsc --noEmit",
    "version": "changeset version",
    "release": "for dir in packages/*; do (cd \"$dir\" && bun publish --if-exists); done && changeset tag"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^26.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsdown": "^0.22.4",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2"
  },
  "packageManager": "bun@1.3.0"
}
